#!/usr/bin/env bash
# MindVault v3 — post-commit 자동 배포 (배포 지연 재발 방지).
#
# 직전 커밋이 deploy 소스(src/·hooks/·skill/·scripts/·install.sh)를 건드렸으면
# 경량 sync(MV3_SYNC_ONLY=1 ./install.sh)로 ~/.claude 배포 경로에 즉시 반영한다.
# 모델/plist/헬스체크/인덱싱은 건너뛰므로 sub-second. 문서 등 비배포 변경은 skip.
#
# core.hooksPath=.githooks 로 와이어링됨 (install.sh 가 자동 설정). post-commit 은
# 반환코드를 git 이 무시하므로 실패해도 커밋엔 영향 없음 — 로그로만 보고.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$ROOT" || exit 0

# 직전 커밋이 바꾼 파일 목록 (첫 커밋이면 부모 없음 → 전체 추적 파일).
if git rev-parse -q --verify HEAD~1 >/dev/null 2>&1; then
  CHANGED="$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null)"
else
  CHANGED="$(git ls-files 2>/dev/null)"
fi

# deploy 소스를 건드린 커밋만 sync (문서/테스트-only 커밋은 무시).
if ! printf '%s\n' "$CHANGED" | grep -Eq '^(src/|hooks/|skill/|scripts/|install\.sh)'; then
  exit 0
fi

LOG="${TMPDIR:-/tmp}/mv3-sync-postcommit.log"
echo "[mv3 post-commit] deploy 소스 변경 감지 → 경량 재배포 (MV3_SYNC_ONLY)…"
if MV3_SYNC_ONLY=1 bash "$ROOT/install.sh" >"$LOG" 2>&1; then
  echo "[mv3 post-commit] ✓ 배포 동기화 완료 (log: $LOG)"
else
  echo "[mv3 post-commit] ⚠ sync 실패 — tail $LOG"
fi
exit 0
