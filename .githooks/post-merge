#!/usr/bin/env bash
# MindVault v3 — post-merge 자동 배포 (git pull/merge 로 받은 변경 반영).
#
# post-commit 과 동일하게, 머지로 들어온 변경이 deploy 소스를 건드렸으면 경량
# sync 로 ~/.claude 배포 경로에 반영한다. 다른 머신에서 푸시한 수정을 pull 했을
# 때 배포본이 stale 로 남는 것을 막는 백스톱.
#
# git 은 post-merge 에 squash 플래그($1)만 넘기고 반환코드는 무시한다.
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$ROOT" || exit 0

# 머지 직전(HEAD@{1}) 대비 바뀐 파일. reflog 없으면 안전하게 전체 sync 로 폴백.
if git rev-parse -q --verify 'HEAD@{1}' >/dev/null 2>&1; then
  CHANGED="$(git diff --name-only 'HEAD@{1}' HEAD 2>/dev/null)"
else
  CHANGED="$(git ls-files 2>/dev/null)"
fi

if ! printf '%s\n' "$CHANGED" | grep -Eq '^(src/|hooks/|skill/|scripts/|install\.sh)'; then
  exit 0
fi

LOG="${TMPDIR:-/tmp}/mv3-sync-postmerge.log"
echo "[mv3 post-merge] deploy 소스 변경 감지 → 경량 재배포 (MV3_SYNC_ONLY)…"
if MV3_SYNC_ONLY=1 bash "$ROOT/install.sh" >"$LOG" 2>&1; then
  echo "[mv3 post-merge] ✓ 배포 동기화 완료 (log: $LOG)"
else
  echo "[mv3 post-merge] ⚠ sync 실패 — tail $LOG"
fi
exit 0
